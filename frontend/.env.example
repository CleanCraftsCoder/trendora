# ===========================
# FRONTEND ENVIRONMENT VARIABLES
# ===========================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env files to git (only .env.example)

# ===========================
# API CONFIGURATION
# ===========================
# Backend API Base URL
VITE_API_BASE_URL=http://localhost:5000/api

# Production API URL
# VITE_API_BASE_URL=https://api.trendora.com/api

# API timeout (milliseconds)
VITE_API_TIMEOUT=30000

# ===========================
# APP CONFIGURATION
# ===========================
# App name
VITE_APP_NAME=Trendora

# App version
VITE_APP_VERSION=1.0.0

# Environment
VITE_ENVIRONMENT=development

# ===========================
# WEBSOCKET CONFIGURATION
# ===========================
# Socket.io server URL
VITE_SOCKET_URL=http://localhost:5000

# Production Socket URL
# VITE_SOCKET_URL=https://api.trendora.com

# ===========================
# IMAGE CONFIGURATION
# ===========================
# CloudFront CDN URL for images
VITE_CDN_URL=http://localhost:5000/uploads

# Production CDN URL
# VITE_CDN_URL=https://cdn.trendora.com

# Image compression quality (0-100)
VITE_IMAGE_QUALITY=80

# Max image upload size (bytes, 5MB = 5242880)
VITE_MAX_FILE_SIZE=5242880

# ===========================
# AUTHENTICATION
# ===========================
# Token storage type: localStorage, sessionStorage
VITE_TOKEN_STORAGE=localStorage

# Token key name
VITE_TOKEN_KEY=accessToken

# Refresh token key name
VITE_REFRESH_TOKEN_KEY=refreshToken

# ===========================
# PAGINATION
# ===========================
# Default items per page
VITE_PAGE_SIZE=20

# ===========================
# FEATURES
# ===========================
# Enable/disable real-time notifications
VITE_ENABLE_NOTIFICATIONS=true

# Enable/disable dark mode
VITE_ENABLE_DARK_MODE=true

# Enable/disable analytics
VITE_ENABLE_ANALYTICS=true

# ===========================
# DEVELOPMENT
# ===========================
# Enable debug mode
VITE_DEBUG=false

# Enable request logging
VITE_LOG_REQUESTS=false

# ===========================
# EXTERNAL SERVICES
# ===========================
# Google Analytics ID (optional)
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Sentry DSN for error tracking (optional)
# VITE_SENTRY_DSN=https://your_sentry_dsn

# ===========================
# UI CONFIGURATION
# ===========================
# Theme: light, dark, auto
VITE_THEME=auto

# Locale: en, es, fr, etc.
VITE_LOCALE=en

# ===========================
# UPLOAD ENDPOINTS
# ===========================
# S3 upload endpoint (for direct upload)
# VITE_S3_UPLOAD_URL=https://your-s3-bucket.s3.amazonaws.com

# Upload API endpoint
VITE_UPLOAD_API=http://localhost:5000/api/uploads
