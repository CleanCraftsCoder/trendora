# ===========================
# BACKEND ENVIRONMENT VARIABLES
# ===========================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to git (only .env.example)

# ===========================
# SERVER CONFIGURATION
# ===========================
NODE_ENV=development
PORT=5000
APP_NAME=Trendora
APP_VERSION=1.0.0

# ===========================
# DATABASE CONFIGURATION
# ===========================
# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/trendora?retryWrites=true&w=majority
MONGODB_TEST_URI=mongodb+srv://username:password@cluster.mongodb.net/trendora_test

# Database name
DB_NAME=trendora

# ===========================
# JWT AUTHENTICATION
# ===========================
# JWT Secret (minimum 32 characters, use strong random string)
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long

# Access token expiry
JWT_ACCESS_EXPIRY=15m

# Refresh token expiry
JWT_REFRESH_EXPIRY=7d

# Refresh token secret
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_32_characters_long

# ===========================
# REDIS CACHE CONFIGURATION
# ===========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# ===========================
# FILE UPLOAD CONFIGURATION
# ===========================
# Multer upload directory
MULTER_UPLOAD_PATH=./uploads

# Maximum file size in bytes (5MB = 5242880)
MAX_FILE_SIZE=5242880

# Allowed file types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif

# ===========================
# AWS S3 / CLOUD STORAGE
# ===========================
# AWS Access Key ID
AWS_ACCESS_KEY_ID=your_aws_access_key

# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# AWS S3 Bucket name
AWS_S3_BUCKET=trendora-uploads

# AWS S3 Region
AWS_S3_REGION=us-east-1

# AWS CloudFront CDN URL (optional)
AWS_CLOUDFRONT_URL=https://your-distribution-id.cloudfront.net

# ===========================
# EMAIL SERVICE CONFIGURATION
# ===========================
# Email service provider (gmail, sendgrid, etc.)
EMAIL_SERVICE=gmail

# Email address
EMAIL_USER=your_email@gmail.com

# Email password or app-specific password
EMAIL_PASSWORD=your_app_specific_password

# Email from name
EMAIL_FROM_NAME=Trendora

# ===========================
# CORS CONFIGURATION
# ===========================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://trendora.com,https://www.trendora.com

# ===========================
# RATE LIMITING
# ===========================
# Rate limit window in milliseconds (60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# Auth endpoint rate limit
AUTH_RATE_LIMIT_MAX=10

# ===========================
# LOGGING CONFIGURATION
# ===========================
# Log level: error, warn, info, debug
LOG_LEVEL=debug

# Log directory
LOG_DIR=./logs

# Log file name
LOG_FILE=app.log

# Maximum log file size (10MB)
LOG_MAX_SIZE=10m

# Keep logs for how many days
LOG_MAX_DAYS=14

# ===========================
# AI SERVICES
# ===========================
# OpenAI API Key (for recommendations, captions, moderation)
OPENAI_API_KEY=sk-your_openai_api_key_here

# OpenAI Model (gpt-4, gpt-3.5-turbo, etc.)
OPENAI_MODEL=gpt-3.5-turbo

# Hugging Face API Key (alternative to OpenAI)
HUGGINGFACE_API_KEY=hf_your_hugging_face_api_key_here

# ===========================
# SOCKET.IO CONFIGURATION
# ===========================
# Socket.io CORS origin
SOCKET_CORS_ORIGIN=http://localhost:3000,https://trendora.com

# Socket.io ping interval (milliseconds)
SOCKET_PING_INTERVAL=25000

# Socket.io ping timeout (milliseconds)
SOCKET_PING_TIMEOUT=60000

# ===========================
# PAGINATION DEFAULTS
# ===========================
# Default page size
DEFAULT_PAGE_SIZE=20

# Maximum page size
MAX_PAGE_SIZE=50

# ===========================
# SECURITY
# ===========================
# Enable/disable HTTPS redirect
HTTPS_REDIRECT=false

# Session secret
SESSION_SECRET=your_session_secret_minimum_32_characters_long

# Bcrypt salt rounds
BCRYPT_SALT_ROUNDS=10

# ===========================
# PAYMENT/SUBSCRIPTION (Future)
# ===========================
# STRIPE_SECRET_KEY=sk_test_your_stripe_key
# STRIPE_PUBLISH_KEY=pk_test_your_stripe_key

# ===========================
# ANALYTICS (Optional)
# ===========================
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# SENTRY_DSN=https://your_sentry_dsn

# ===========================
# DEVELOPMENT/DEBUG
# ===========================
# Enable debug mode
DEBUG=false

# Mock external services (for testing)
MOCK_EXTERNAL_SERVICES=false

# Print SQL queries
PRINT_QUERIES=false

# ===========================
# CLOUDINARY CONFIGURATION
# ===========================
# Cloudinary cloud name
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary api key
CLOUDINARY_API_KEY=your_api_key

# Cloudinary api secret
CLOUDINARY_API_SECRET=your_api_secret

